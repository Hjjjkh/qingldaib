{
  "name": "couple-commitment-tracker",
  "version": "1.0.0",
  "description": "情侣约定记录系统 - 共同记录见面后要做的事情",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "build": "npm run build --workspace=frontend",
    "preview": "wrangler pages dev frontend/dist",
    "deploy": "npx wrangler pages deploy frontend/dist"
  },
  "devDependencies": {
    "wrangler": "^3.114.17"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
